{
  "expo": {
    "name": "Dancify",
    "slug": "dancify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.isyumj.dancify",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Dancify needs access to your photo library to let you import local videos for dance practice."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [],
      "package": "com.isyumj.dancify"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "dancify",
    "plugins": [
      "expo-router",
      "expo-video",
      [
        "expo-audio",
        {
          "microphonePermission": false,
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ],
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Dancify needs access to your photo library to let you import local videos for dance practice.",
          "cameraPermission": false
        }
      ],
      "expo-localization",
      "expo-font",
      "expo-asset",
      "expo-image"
    ]
  }
}
