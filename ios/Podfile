# Set by expo-router. This enables Fabric-only features from react-native-screens
ENV['RNS_GAMMA_ENABLED'] ||= '1'
require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

def ccache_enabled?(podfile_properties)
  # Environment variable takes precedence
  return ENV['USE_CCACHE'] == '1' if ENV['USE_CCACHE']

  # Fall back to Podfile properties
  podfile_properties['apple.ccacheEnabled'] == 'true'
end

ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] ||= podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']
ENV['RCT_USE_RN_DEP'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true'
ENV['RCT_USE_PREBUILT_RNCORE'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true'
ENV['RCT_HERMES_V1_ENABLED'] ||= '1' if podfile_properties['expo.useHermesV1'] == 'true'
platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'

project 'Dancify.xcodeproj'

prepare_react_native_project!

target 'Dancify' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(\'expo/bin/autolinking\')',
      'expo-modules-autolinking',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => ccache_enabled?(podfile_properties),
    )

    # expo-av v16 references legacy EXEventEmitter headers removed in expo-modules-core v55
    expo_headers_dir = File.join(installer.sandbox.root, "Headers/Public/ExpoModulesCore/ExpoModulesCore")
    shims = {
      "EXEventEmitter.h" => <<~HEADER,
        // Compatibility shim for expo-av legacy event emitter protocol
        #import <Foundation/Foundation.h>
        @protocol EXEventEmitter <NSObject>
        - (NSArray<NSString *> *)supportedEvents;
        - (void)startObserving;
        - (void)stopObserving;
        @end
      HEADER
      "EXEventEmitterService.h" => <<~HEADER,
        // Compatibility shim for expo-av legacy event emitter service protocol
        #import <Foundation/Foundation.h>
        @protocol EXEventEmitterService <NSObject>
        - (void)sendEventWithName:(NSString *)eventName body:(id)body;
        @end
      HEADER
      "EXLegacyExpoViewProtocol.h" => <<~HEADER,
        // Compatibility shim for expo-av legacy view protocol
        #import <Foundation/Foundation.h>
        @protocol EXLegacyExpoViewProtocol <NSObject>
        @end
      HEADER
    }
    shims.each do |filename, content|
      path = File.join(expo_headers_dir, filename)
      File.write(path, content) unless File.exist?(path)
    end

    # Patch EXDefines.h to add EXFatal/EXErrorWithMessage removed in expo-modules-core v55
    exdefines_path = File.join(expo_headers_dir, "EXDefines.h")
    if File.exist?(exdefines_path) && !File.read(exdefines_path).include?("EXErrorWithMessage")
      patch = <<~PATCH

        // Compatibility shims removed in expo-modules-core v55 but still used by expo-av v16
        static inline NSError *EXErrorWithMessage(NSString *message) {
          return [NSError errorWithDomain:@"EXShimError" code:-1 userInfo:@{NSLocalizedDescriptionKey: message}];
        }

        static inline void EXFatal(NSError *error) {
          NSLog(@"[Expo] Fatal: %@", error.localizedDescription);
        }

        #define EXLogInfo(...)  NSLog(__VA_ARGS__)
        #define EXLogWarn(...)  NSLog(__VA_ARGS__)
        #define EXLogError(...) NSLog(__VA_ARGS__)

        // UM-prefix aliases removed in expo-modules-core v55, still used by expo-av v16
        typedef EXPromiseResolveBlock UMPromiseResolveBlock;
        typedef EXPromiseRejectBlock UMPromiseRejectBlock;
      PATCH
      File.open(exdefines_path, "a") { |f| f.write(patch) }
    end

    # Add shim headers to the umbrella header so the module map picks them up
    umbrella_path = File.join(installer.sandbox.root, "Headers/Public/ExpoModulesCore/ExpoModulesCore-umbrella.h")
    if File.exist?(umbrella_path)
      umbrella = File.read(umbrella_path)
      shims.each_key do |filename|
        import_line = "#import \"ExpoModulesCore/#{filename}\""
        unless umbrella.include?(import_line)
          umbrella = umbrella.sub(
            '#import "ExpoModulesCore/EXAppLifecycleListener.h"',
            "#import \"ExpoModulesCore/EXAppLifecycleListener.h\"\n#{import_line}"
          )
        end
      end
      File.write(umbrella_path, umbrella)
    end
  end
end
